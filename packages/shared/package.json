{
  "name": "@foundry-toolkit/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Types and shared UI components used across the DM app and player portal. Consumers provide React via peerDependencies.",
  "exports": {
    ".": "./src/types.ts",
    "./types": "./src/types.ts",
    "./env": "./src/env.ts",
    "./env-auto": "./src/env-auto.ts",
    "./foundry-api": "./src/foundry-api.ts",
    "./foundry-markup": "./src/foundry-markup.ts",
    "./http": "./src/http.ts",
    "./map-stem": "./src/map-stem.ts",
    "./MissionBriefing": "./src/MissionBriefing.tsx",
    "./golarion-map": "./src/golarion-map/index.ts",
    "./rpc": "./src/rpc/index.ts",
    "./tokens": "./src/tokens/index.ts",
    "./tokens/pf2e.css": {
      "style": "./src/tokens/pf2e.css",
      "default": "./src/tokens/pf2e.css"
    },
    "./tokens/fonts.css": {
      "style": "./src/tokens/fonts.css",
      "default": "./src/tokens/fonts.css"
    },
    "./tokens/color-schemes.css": {
      "style": "./src/tokens/color-schemes.css",
      "default": "./src/tokens/color-schemes.css"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@iconify-json/game-icons": "^1.2.3",
    "dotenv": "^16.6.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "maplibre-gl": ">=5",
    "react": ">=19"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.14",
    "@types/react": "^19.2.14",
    "maplibre-gl": "^5.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
