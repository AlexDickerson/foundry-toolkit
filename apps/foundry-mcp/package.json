{
  "name": "@foundry-toolkit/mcp",
  "version": "1.3.0",
  "description": "Self-hosted MCP server that bridges Claude Code to a Foundry VTT instance over WebSocket",
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file-if-exists=../../.env --env-file-if-exists=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@foundry-toolkit/shared": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastify": "^5.3.2",
    "openai": "^6.35.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.5.0",
    "eslint": "^10.2.1",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
