{
  "version": "0.2.0",
  "configurations": [
    {
      //  preLaunchTask "local: up" runs ./local.sh via Git Bash on
      //  Windows (PowerShell's default `bash` resolves to WSL's bash.exe
      //  and breaks). After the container is detached and running, the
      //  launch command tails container logs so you can see Foundry
      //  startup; hit Stop or Ctrl+C to end the log tail — the container
      //  keeps running. Stop it via the "local: stop" task or Docker
      //  Desktop. First-time setup needs .env with FOUNDRY_USERNAME/
      //  PASSWORD next to docker-compose.local.yml.
      "name": "1. Foundry + API Bridge (Docker)",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/foundry-api-bridge",
      "command": "docker compose -f docker-compose.local.yml logs -f --tail=100",
      "preLaunchTask": "local: up"
    },
    {
      //  Launches the MCP server on the HOST via tsx (no Docker) with
      //  VS Code's Node debugger attached. Breakpoints in apps/foundry-mcp/src
      //  work. Port 8765 must be free. This is the primary iteration path —
      //  the api-bridge container is where Foundry runs; the MCP server is
      //  a separate host process that connects to Foundry via WebSocket.
      "name": "2. MCP Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/apps/foundry-mcp",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      //  Vite dev server on :5173. Proxies /api → :8765 (foundry-mcp)
      //  and Foundry asset prefixes → :30000 (api-bridge container).
      //  Prefer "3a. Debug Character Creator (Chrome)" if you want
      //  breakpoints in React components.
      "name": "3. Character Creator (Vite)",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/character-creator",
      "command": "npm run dev"
    },
    {
      //  Launches Chrome against the Vite dev server at :5173. preLaunchTask
      //  boots Vite first and waits for the "ready in" banner before Chrome
      //  opens, so the attach doesn't race the server startup.
      "name": "3a. Debug Character Creator (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/apps/character-creator/src",
      "preLaunchTask": "character-creator: dev",
      "sourceMaps": true
    },
    {
      //  electron-vite dev — main process (Node) + renderer (Chromium).
      //  electron-vite enables --inspect on the main process automatically;
      //  open chrome://inspect or attach via "Debug DM Tool (Electron main)"
      //  if you want breakpoints in the main process. Renderer breakpoints
      //  go through Chrome DevTools on the Electron window (Ctrl+Shift+I).
      "name": "4. DM Tool (Electron)",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/dm-tool",
      "command": "npm run dev"
    },
    {
      "name": "Debug api-bridge tests (Jest)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test", "--", "--runInBand"],
      "cwd": "${workspaceFolder}/apps/foundry-api-bridge",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug character-creator tests (Vitest)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test"],
      "cwd": "${workspaceFolder}/apps/character-creator",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug dm-tool tests (Vitest)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test"],
      "cwd": "${workspaceFolder}/apps/dm-tool",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "5. All together",
      "configurations": [
        "1. Foundry + API Bridge (Docker)",
        "2. MCP Server",
        "3. Character Creator (Vite)",
        "4. DM Tool (Electron)"
      ],
      "stopAll": true
    }
  ]
}
