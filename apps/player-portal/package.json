{
  "name": "@foundry-toolkit/player-portal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Player-facing web app plus its live-sync server. One Fastify process serves the SPA, /api/live/* (ex-sidecar snapshots), /api/mcp/* (proxy to foundry-mcp), /map/* (tile proxy), and the bare Foundry asset prefixes.",
  "scripts": {
    "dev": "concurrently -n vite,server -c auto \"vite\" \"tsx watch server/index.ts\"",
    "dev:client": "vite",
    "dev:mock": "vite --mode mock",
    "dev:server": "tsx watch server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "tsc --noEmit && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node server-dist/index.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.scripts.json",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "user:add": "tsx scripts/user-add.ts",
    "user:list": "tsx scripts/user-list.ts",
    "user:reset-password": "tsx scripts/user-reset-password.ts",
    "user:remove": "tsx scripts/user-remove.ts"
  },
  "dependencies": {
    "@fastify/http-proxy": "^11.0.0",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/static": "^9.1.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.3.2",
    "lucide-react": "^1.14.0",
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@foundry-toolkit/pf2e-rules": "*",
    "@foundry-toolkit/shared": "*",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.1.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.0",
    "postcss": "^8.5.12",
    "sass": "^1.82.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  }
}
