{
  "name": "@foundry-toolkit/player-portal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Player-facing web app plus its live-sync server. One Fastify process serves the SPA, the /api/* inventory + leaderboard routes (ex-sidecar), and the /map/* tile proxy.",
  "scripts": {
    "dev": "concurrently -n vite,server -c auto \"vite\" \"tsx watch server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node server-dist/index.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fastify/http-proxy": "^11.0.0",
    "@fastify/static": "^9.1.1",
    "@fastify/websocket": "^11.0.2",
    "fastify": "^5.3.2",
    "maplibre-gl": "^5.23.0",
    "pmtiles": "^4.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@foundry-toolkit/shared": "*",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.1.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.2"
  }
}
