# npm 7+ strictly enforces peer deps, which trips on @league-of-foundry-developers/foundry-vtt-types
# vs. the project's bleeding-edge TypeScript pin. The installed combination works at runtime and at
# type-check time; the conflict is a resolver artifact. Revert to npm 6 peer-dep behaviour so plain
# `npm install` (via local.sh, VS Code tasks, or CLI) works without --legacy-peer-deps flags.
legacy-peer-deps=true
