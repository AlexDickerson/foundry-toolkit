{
  "name": "@foundry-toolkit/dm-tool",
  "version": "1.5.0",
  "description": "DM desktop app: Electron + React + SQLite. Browses the dnd-map-tagger index, drives Foundry VTT via MCP, runs the chat/loot AI, and pushes state to the sidecar for the player portal.",
  "author": "Alex Dickerson",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "package": "electron-vite build && electron-builder --win",
    "package:dir": "electron-vite build && electron-builder --win --dir",
    "package:ci": "electron-vite build && electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.alexdickerson.dm-tool",
    "productName": "DM Tool",
    "directories": {
      "output": "../../dist",
      "buildResources": "../../resources"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "../../resources/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "extraResources": [
      {
        "from": "../../tagger/dist/map-tagger.exe",
        "to": "map-tagger.exe"
      },
      {
        "from": "../../auto-wall-bin/Auto-Wall.exe",
        "to": "Auto-Wall.exe"
      }
    ],
    "npmRebuild": true,
    "nodeGypRebuild": false,
    "asar": true
  },
  "dependencies": {
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/crimson-pro": "^5.2.8",
    "@foundry-toolkit/ai": "*",
    "@foundry-toolkit/db": "*",
    "@foundry-toolkit/shared": "*",
    "@iconify-json/game-icons": "^1.2.3",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.2.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.1.0",
    "@tanstack/react-virtual": "^3.13.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "maplibre-gl": "^5.23.0",
    "pdfjs-dist": "^5.6.205",
    "pmtiles": "^4.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "electron": "41.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.4"
  }
}
