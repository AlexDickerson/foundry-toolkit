# OpenAI API key (required for edit_image tool - GPT-image-1 map editing)
OPENAI_API_KEY=sk-your-openai-api-key

# Opt-in: enables POST /api/eval. Leave unset in production.
# ALLOW_EVAL=1

# Root directory for purchased PF2e item-card PNGs served at /item-art/*.
# If unset, /item-art/* returns 404 (safe default — no art served).
# FOUNDRY_MCP_ITEM_ART_DIR=/data/item-art
