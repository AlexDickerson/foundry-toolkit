# foundry-api-bridge pins @league-of-foundry-developers/foundry-vtt-types against a bleeding-edge TypeScript, which
# trips npm 7+ strict peer-dep resolution. legacy-peer-deps mirrors the old npm 6 resolver and is required for
# plain `npm install` to succeed at the monorepo root. Safe for the other workspaces — no behavioural change.
legacy-peer-deps=true
